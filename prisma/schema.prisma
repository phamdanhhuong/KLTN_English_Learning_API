// KLTN English Learning API - Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum ProficiencyLevel {
  BEGINNER
  ELEMENTARY
  INTERMEDIATE
  UPPER_INTERMEDIATE
  ADVANCED
  PROFICIENT
}

enum LearningGoal {
  CONNECT
  TRAVEL
  STUDY
  ENTERTAINMENT
  CAREER
  HOBBY
}

enum CurrencyType {
  GEMS
  COINS
}

enum CurrencyTransactionReason {
  LESSON_COMPLETED
  STREAK_MILESTONE
  ACHIEVEMENT_REWARD
  QUEST_REWARD
  PURCHASE
  LEVEL_UP_REWARD
  ADMIN_ADJUSTMENT
  REFUND
}

enum ExerciseType {
  translate
  listen_choose
  fill_blank
  speak
  match
  multiple_choice
  writing_prompt
  image_description
  read_comprehension
  podcast
  compare_words
  pronunciation_vowel
  pronunciation_consonant
  pronunciation_word
}

// ==================== QUEST ENUMS ====================

enum QuestType {
  DAILY
  FRIENDS
  MONTHLY_BADGE
}

enum QuestCategory {
  LESSONS
  EXERCISES
  XP_EARNED
  FRIENDS_CHALLENGE
  COLLECTION
  STREAK
}

enum QuestStatus {
  ACTIVE
  COMPLETED
  CLAIMED
  EXPIRED
}

enum DifficultyLevel {
  EASY
  NORMAL
  HARD
  EXPERT
}

enum ChestType {
  BRONZE
  SILVER
  GOLD
  LEGENDARY
}

enum ChestStatus {
  LOCKED
  UNLOCKED
  OPENED
}

// ==================== LEADERBOARD ENUMS ====================

enum LeagueTier {
  BRONZE
  SILVER
  GOLD
  SAPPHIRE
  RUBY
  EMERALD
  AMETHYST
  PEARL
  OBSIDIAN
  DIAMOND
}

enum LeagueStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

// ==================== REPORT/BLOCK ENUMS ====================

enum ReportReason {
  SPAM
  HARASSMENT
  INAPPROPRIATE_CONTENT
  FAKE_ACCOUNT
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

// ==================== AUTH MODULE ====================

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  password        String?
  googleId        String?   @unique @map("google_id")
  facebookId      String?   @unique @map("facebook_id")
  isEmailVerified Boolean   @default(false) @map("is_email_verified")
  isActive        Boolean   @default(true) @map("is_active")
  lastLoginAt     DateTime? @map("last_login_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  role      Role           @relation(fields: [roleId], references: [id])
  roleId    String         @map("role_id")
  refreshTokens RefreshToken[]

  // ==================== USER PROFILE ====================
  username          String?           @unique
  fullName          String?           @map("full_name")
  profilePictureUrl String?           @map("profile_picture_url")
  dateOfBirth       DateTime?         @map("date_of_birth")
  gender            Gender?

  // Learning preferences
  nativeLanguage   String?           @default("vi") @map("native_language")
  targetLanguage   String?           @default("en") @map("target_language")
  proficiencyLevel ProficiencyLevel? @map("proficiency_level")
  learningGoals    LearningGoal[]
  dailyGoalMinutes Int               @default(15) @map("daily_goal_minutes")
  timezone         String?           @default("Asia/Ho_Chi_Minh")

  // XP & Level (không tách bảng riêng)
  xpPoints      Int @default(0) @map("xp_points")
  currentLevel  Int @default(1) @map("current_level")
  totalXpEarned Int @default(0) @map("total_xp_earned")

  // Gamification relations
  currency             UserCurrency?
  streakData           StreakData?
  energy               UserEnergy?
  currencyTransactions CurrencyTransaction[]
  dailyActivities      UserDailyActivity[]

  // Social relations
  following      UserRelationship[] @relation("UserFollowing")
  followers      UserRelationship[] @relation("UserFollowers")
  blockedUsers   UserBlock[]        @relation("Blocker")
  blockedBy      UserBlock[]        @relation("Blocked")
  sentReports    UserReport[]       @relation("Reporter")
  receivedReports UserReport[]      @relation("Reported")

  // Achievement & Quest relations
  userAchievements         UserAchievement[]
  userQuests               UserQuest[]
  friendsQuestParticipants FriendsQuestParticipant[]

  // Leaderboard relations
  leagueParticipations LeagueParticipant[]
  leagueHistories      LeagueHistory[]
  leagueTier           UserLeagueTier?

  // Feed relations
  feedPosts     FeedPost[]
  feedReactions FeedReaction[]
  feedComments  FeedComment[]

  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  users       User[]

  @@map("roles")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  isRevoked Boolean  @default(false) @map("is_revoked")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ==================== USER MODULE ====================

model UserCurrency {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  gems      Int      @default(0)
  coins     Int      @default(100)
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_currency")
}

model CurrencyTransaction {
  id           String                    @id @default(uuid())
  userId       String                    @map("user_id")
  currencyType CurrencyType              @map("currency_type")
  amount       Int
  reason       CurrencyTransactionReason
  metadata     Json?
  createdAt    DateTime                  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@map("currency_transactions")
}

model StreakData {
  id            String    @id @default(uuid())
  userId        String    @unique @map("user_id")
  currentStreak Int       @default(0) @map("current_streak")
  longestStreak Int       @default(0) @map("longest_streak")
  lastStudyDate DateTime? @map("last_study_date") @db.Date
  freezeCount   Int       @default(0) @map("freeze_count")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  history StreakHistory[]

  @@map("streak_data")
}

model StreakHistory {
  id           String   @id @default(uuid())
  streakDataId String   @map("streak_data_id")
  streakLength Int      @map("streak_length")
  startDate    DateTime @map("start_date") @db.Date
  endDate      DateTime @map("end_date") @db.Date
  endReason    String   @map("end_reason")
  createdAt    DateTime @default(now()) @map("created_at")

  streakData StreakData @relation(fields: [streakDataId], references: [id], onDelete: Cascade)

  @@index([streakDataId])
  @@map("streak_history")
}

model UserDailyActivity {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  activityDate  DateTime @map("activity_date") @db.Date
  xpEarned      Int      @default(0) @map("xp_earned")
  lessonsCount  Int      @default(0) @map("lessons_count")
  exerciseCount Int      @default(0) @map("exercise_count")
  streakCount   Int      @default(0) @map("streak_count")
  freezeUsed    Boolean  @default(false) @map("freeze_used")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, activityDate])
  @@index([userId, activityDate])
  @@map("user_daily_activities")
}

model UserEnergy {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  currentEnergy   Int      @default(5) @map("current_energy")
  maxEnergy       Int      @default(5) @map("max_energy")
  lastRechargeAt  DateTime @default(now()) @map("last_recharge_at")
  rechargeRateMin Int      @default(30) @map("recharge_rate_min")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_energy")
}

model UserLevel {
  level       Int     @id
  minXp       Int     @map("min_xp")
  maxXp       Int     @map("max_xp")
  title       String
  iconUrl     String? @map("icon_url")
  rewardGems  Int     @default(0) @map("reward_gems")
  rewardCoins Int     @default(0) @map("reward_coins")

  @@map("user_levels")
}


// ==================== SKILL / LEARNING MODULE ====================

model SkillPart {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(255)
  description String?  @db.Text
  position    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  skills Skill[]

  @@map("skill_parts")
}

model Skill {
  id          String   @id @default(uuid())
  title       String   @db.VarChar(255)
  description String?  @db.Text
  position    Int      @default(0)
  partId      String   @map("part_id")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  part           SkillPart       @relation(fields: [partId], references: [id], onDelete: Cascade)
  skillLevels    SkillLevel[]
  lessons        Lesson[]
  skillProgress  SkillProgress[]
  skillWords     SkillWord[]
  skillGrammars  SkillGrammar[]

  @@map("skills")
}

model SkillLevel {
  skillId String @map("skill_id")
  level   Int

  skill   Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@id([skillId, level])
  @@map("skill_levels")
}

model Lesson {
  id         String   @id @default(uuid())
  skillId    String   @map("skill_id")
  skillLevel Int      @map("skill_level")
  title      String   @db.VarChar(255)
  position   Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  skill     Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)
  skillLvl  SkillLevel @relation(fields: [skillId, skillLevel], references: [skillId, level], onDelete: Cascade)
  exercises Exercise[]

  @@map("lessons")
}

model Word {
  id            String   @id @default(uuid())
  content       String   @unique @db.VarChar(255)
  pronunciation String?  @db.VarChar(255)
  meaning       String?  @db.Text
  audioUrl      String?  @map("audio_url") @db.VarChar(255)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  wordMastery   WordMastery[]
  exerciseWords ExerciseWord[]
  skillWords    SkillWord[]
  wordTags      WordTag[]

  @@map("words")
}

model Grammar {
  id          String   @id @default(uuid())
  rule        String   @db.Text
  explanation String?  @db.Text
  examples    Json?    @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  grammarMastery   GrammarMastery[]
  exerciseGrammars ExerciseGrammar[]
  skillGrammars    SkillGrammar[]

  @@map("grammars")
}

model Tag {
  id   String @id @default(uuid())
  name String @unique @db.VarChar(50)

  wordTags WordTag[]

  @@map("tags")
}

model Exercise {
  id           String       @id @default(uuid())
  lessonId     String       @map("lesson_id")
  exerciseType ExerciseType @map("exercise_type")
  prompt       String?      @db.Text
  meta         Json?        @db.JsonB
  position     Int          @default(0)
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  lesson           Lesson            @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  exerciseWords    ExerciseWord[]
  exerciseGrammars ExerciseGrammar[]
  exerciseResults  ExerciseResult[]

  @@map("exercises")
}

// ==================== PROGRESS TRACKING ====================

model SkillProgress {
  userId         String    @id @map("user_id")
  skillId        String    @map("skill_id")
  levelReached   Int       @default(1) @map("level_reached")
  lessonPosition Int       @default(0) @map("lesson_position")
  lastPracticed  DateTime? @map("last_practiced") @db.Timestamptz(6)

  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@map("skill_progress")
}

model WordMastery {
  userId       String    @map("user_id")
  wordId       String    @map("word_id")
  masteryLevel Int       @default(0) @map("mastery_level")
  lastReview   DateTime? @map("last_review") @db.Timestamptz(6)

  word Word @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@id([userId, wordId])
  @@map("word_mastery")
}

model GrammarMastery {
  userId       String    @map("user_id")
  grammarId    String    @map("grammar_id")
  masteryLevel Int       @default(0) @map("mastery_level")
  lastReview   DateTime? @map("last_review") @db.Timestamptz(6)

  grammar Grammar @relation(fields: [grammarId], references: [id], onDelete: Cascade)

  @@id([userId, grammarId])
  @@map("grammar_mastery")
}

model ExerciseResult {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  exerciseId     String   @map("exercise_id")
  correctCount   Int      @map("correct_count") @default(0)
  incorrectCount Int      @map("incorrect_count") @default(0)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@map("exercise_results")
}

// ==================== JUNCTION TABLES ====================

model ExerciseWord {
  exerciseId String @map("exercise_id")
  wordId     String @map("word_id")

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  word     Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@id([exerciseId, wordId])
  @@map("exercise_words")
}

model ExerciseGrammar {
  exerciseId String @map("exercise_id")
  grammarId  String @map("grammar_id")

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  grammar  Grammar  @relation(fields: [grammarId], references: [id], onDelete: Cascade)

  @@id([exerciseId, grammarId])
  @@map("exercise_grammars")
}

model SkillWord {
  skillId String @map("skill_id")
  wordId  String @map("word_id")

  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)
  word  Word  @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@id([skillId, wordId])
  @@map("skill_words")
}

model SkillGrammar {
  skillId   String @map("skill_id")
  grammarId String @map("grammar_id")

  skill   Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)
  grammar Grammar @relation(fields: [grammarId], references: [id], onDelete: Cascade)

  @@id([skillId, grammarId])
  @@map("skill_grammars")
}

model WordTag {
  wordId String @map("word_id")
  tagId  String @map("tag_id")

  word Word @relation(fields: [wordId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([wordId, tagId])
  @@map("word_tags")
}

// ==================== SOCIAL MODULE ====================

model UserRelationship {
  id          String   @id @default(uuid())
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")

  follower  User @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("user_relationships")
}

model UserBlock {
  id            String   @id @default(uuid())
  blockerId     String   @map("blocker_id")
  blockedUserId String   @map("blocked_user_id")
  createdAt     DateTime @default(now()) @map("created_at")

  blocker     User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedUser User @relation("Blocked", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedUserId])
  @@index([blockerId])
  @@index([blockedUserId])
  @@map("user_blocks")
}

model UserReport {
  id             String       @id @default(uuid())
  reporterId     String       @map("reporter_id")
  reportedUserId String       @map("reported_user_id")
  reason         ReportReason
  description    String?
  status         ReportStatus @default(PENDING)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  reporter     User @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedUser User @relation("Reported", fields: [reportedUserId], references: [id], onDelete: Cascade)

  @@index([reportedUserId])
  @@index([reporterId])
  @@index([status])
  @@map("user_reports")
}

// ==================== ACHIEVEMENT MODULE ====================

model Achievement {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  description String
  iconUrl     String?  @map("icon_url")
  badgeUrl    String?  @map("badge_url")
  category    String
  tier        Int      @default(1)
  requirement Int
  rewardXp    Int      @default(0) @map("reward_xp")
  rewardGems  Int      @default(0) @map("reward_gems")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  userAchievements UserAchievement[]

  @@index([category, tier])
  @@map("achievements")
}

model UserAchievement {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  achievementId String    @map("achievement_id")
  progress      Int       @default(0)
  isUnlocked    Boolean   @default(false) @map("is_unlocked")
  unlockedAt    DateTime? @map("unlocked_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId, isUnlocked])
  @@map("user_achievements")
}

// ==================== QUEST MODULE ====================

model Quest {
  id                  String        @id @default(uuid())
  key                 String        @unique
  type                QuestType
  category            QuestCategory
  name                String
  description         String
  iconUrl             String?       @map("icon_url")
  baseRequirement     Int           @map("base_requirement")
  rewardXp            Int           @default(0) @map("reward_xp")
  rewardGems          Int           @default(0) @map("reward_gems")
  chestType           ChestType?    @map("chest_type")
  badgeIconUrl        String?       @map("badge_icon_url")
  order               Int           @default(0)
  isActive            Boolean       @default(true) @map("is_active")
  requiresMultiplayer Boolean       @default(false) @map("requires_multiplayer")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  userQuests UserQuest[]

  @@index([type, isActive])
  @@index([category])
  @@map("quests")
}

model UserQuest {
  id              String          @id @default(uuid())
  userId          String          @map("user_id")
  questId         String          @map("quest_id")
  progress        Int             @default(0)
  requirement     Int
  difficultyLevel DifficultyLevel @default(NORMAL) @map("difficulty_level")
  status          QuestStatus     @default(ACTIVE)
  startDate       DateTime        @map("start_date")
  endDate         DateTime        @map("end_date")
  completedAt     DateTime?       @map("completed_at")
  claimedAt       DateTime?       @map("claimed_at")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  quest Quest      @relation(fields: [questId], references: [id], onDelete: Cascade)
  chest QuestChest?

  @@unique([userId, questId, startDate])
  @@index([userId, status])
  @@index([userId, endDate])
  @@map("user_quests")
}

model QuestChest {
  id             String      @id @default(uuid())
  userQuestId    String      @unique @map("user_quest_id")
  chestType      ChestType   @map("chest_type")
  status         ChestStatus @default(LOCKED)
  rewardXp       Int         @default(0) @map("reward_xp")
  rewardGems     Int         @default(0) @map("reward_gems")
  rewardCoins    Int         @default(0) @map("reward_coins")
  xpBoostMinutes Int?        @map("xp_boost_minutes")
  badgeId        String?     @map("badge_id")
  unlockedAt     DateTime?   @map("unlocked_at")
  openedAt       DateTime?   @map("opened_at")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  userQuest UserQuest @relation(fields: [userQuestId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("quest_chests")
}

model FriendsQuestParticipant {
  id            String   @id @default(uuid())
  questKey      String   @map("quest_key")
  userId        String   @map("user_id")
  weekStartDate DateTime @map("week_start_date")
  contribution  Int      @default(0)
  isCreator     Boolean  @default(false) @map("is_creator")
  joinedAt      DateTime @default(now()) @map("joined_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([questKey, userId, weekStartDate])
  @@index([userId, weekStartDate])
  @@index([questKey, weekStartDate])
  @@map("friends_quest_participants")
}

// ==================== LEADERBOARD MODULE ====================

model League {
  id            String       @id @default(uuid())
  tier          LeagueTier
  weekStartDate DateTime     @map("week_start_date")
  weekEndDate   DateTime     @map("week_end_date")
  status        LeagueStatus @default(ACTIVE)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  groups LeagueGroup[]

  @@unique([tier, weekStartDate])
  @@index([tier, status])
  @@index([weekStartDate, weekEndDate])
  @@map("leagues")
}

model LeagueGroup {
  id               String   @id @default(uuid())
  leagueId         String   @map("league_id")
  groupNumber      Int      @map("group_number")
  participantCount Int      @default(0) @map("participant_count")
  maxParticipants  Int      @default(30) @map("max_participants")
  isFull           Boolean  @default(false) @map("is_full")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  league       League             @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  participants LeagueParticipant[]

  @@unique([leagueId, groupNumber])
  @@index([leagueId, isFull])
  @@map("league_groups")
}

model LeagueParticipant {
  id           String   @id @default(uuid())
  groupId      String   @map("group_id")
  userId       String   @map("user_id")
  weeklyXp     Int      @default(0) @map("weekly_xp")
  rank         Int?
  isPromoted   Boolean  @default(false) @map("is_promoted")
  isDemoted    Boolean  @default(false) @map("is_demoted")
  joinedAt     DateTime @default(now()) @map("joined_at")
  lastXpUpdate DateTime @default(now()) @map("last_xp_update")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  group LeagueGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId, weeklyXp])
  @@index([userId])
  @@map("league_participants")
}

model LeagueHistory {
  id            String     @id @default(uuid())
  userId        String     @map("user_id")
  tier          LeagueTier
  weekStartDate DateTime   @map("week_start_date")
  weeklyXp      Int        @map("weekly_xp")
  rank          Int
  outcome       String     // "PROMOTED", "MAINTAINED", "DEMOTED"
  createdAt     DateTime   @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, weekStartDate])
  @@index([userId, tier])
  @@map("league_histories")
}

model UserLeagueTier {
  id               String     @id @default(uuid())
  userId           String     @unique @map("user_id")
  currentTier      LeagueTier @default(BRONZE) @map("current_tier")
  currentGroupId   String?    @map("current_group_id")
  consecutiveWeeks Int        @default(0) @map("consecutive_weeks")
  totalPromotions  Int        @default(0) @map("total_promotions")
  totalDemotions   Int        @default(0) @map("total_demotions")
  highestTier      LeagueTier @default(BRONZE) @map("highest_tier")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([currentTier])
  @@map("user_league_tiers")
}

// ==================== FEED ====================

enum FeedPostType {
  STREAK_MILESTONE
  LEAGUE_PROMOTION
  LEAGUE_TOP_3
  NEW_FOLLOWER
  ACHIEVEMENT_UNLOCKED
  LEVEL_UP
  QUEST_COMPLETED
  PERFECT_SCORE
  XP_MILESTONE
}

enum FeedReactionType {
  CONGRATS
  FIRE
  CLAP
  HEART
  STRONG
}

model FeedPost {
  id        String       @id @default(uuid())
  userId    String       @map("user_id")
  postType  FeedPostType @map("post_type")
  content   String
  metadata  Json?
  imageUrl  String?      @map("image_url")
  isVisible Boolean      @default(true) @map("is_visible")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions FeedReaction[]
  comments  FeedComment[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([isVisible, createdAt(sort: Desc)])
  @@map("feed_posts")
}

model FeedReaction {
  id           String          @id @default(uuid())
  postId       String          @map("post_id")
  userId       String          @map("user_id")
  reactionType FeedReactionType @map("reaction_type")
  createdAt    DateTime        @default(now()) @map("created_at")

  post FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
  @@map("feed_reactions")
}

model FeedComment {
  id        String   @id @default(uuid())
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  content   String
  isEdited  Boolean  @default(false) @map("is_edited")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  post FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([userId])
  @@map("feed_comments")
}
