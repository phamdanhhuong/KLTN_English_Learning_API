// KLTN English Learning API - Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum ProficiencyLevel {
  BEGINNER
  ELEMENTARY
  INTERMEDIATE
  UPPER_INTERMEDIATE
  ADVANCED
  PROFICIENT
}

enum LearningGoal {
  CONNECT
  TRAVEL
  STUDY
  ENTERTAINMENT
  CAREER
  HOBBY
}

enum CurrencyType {
  GEMS
  COINS
}

enum CurrencyTransactionReason {
  LESSON_COMPLETED
  STREAK_MILESTONE
  ACHIEVEMENT_REWARD
  QUEST_REWARD
  PURCHASE
  LEVEL_UP_REWARD
  ADMIN_ADJUSTMENT
  REFUND
}

enum ExerciseType {
  translate
  listen_choose
  fill_blank
  speak
  match
  multiple_choice
  writing_prompt
  image_description
  read_comprehension
  podcast
  compare_words
  pronunciation_vowel
  pronunciation_consonant
  pronunciation_word
}

// ==================== AUTH MODULE ====================

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  password        String?
  googleId        String?   @unique @map("google_id")
  facebookId      String?   @unique @map("facebook_id")
  isEmailVerified Boolean   @default(false) @map("is_email_verified")
  isActive        Boolean   @default(true) @map("is_active")
  lastLoginAt     DateTime? @map("last_login_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  role      Role           @relation(fields: [roleId], references: [id])
  roleId    String         @map("role_id")
  refreshTokens RefreshToken[]

  // ==================== USER PROFILE ====================
  username          String?           @unique
  fullName          String?           @map("full_name")
  profilePictureUrl String?           @map("profile_picture_url")
  dateOfBirth       DateTime?         @map("date_of_birth")
  gender            Gender?

  // Learning preferences
  nativeLanguage   String?           @default("vi") @map("native_language")
  targetLanguage   String?           @default("en") @map("target_language")
  proficiencyLevel ProficiencyLevel? @map("proficiency_level")
  learningGoals    LearningGoal[]
  dailyGoalMinutes Int               @default(15) @map("daily_goal_minutes")
  timezone         String?           @default("Asia/Ho_Chi_Minh")

  // XP & Level (không tách bảng riêng)
  xpPoints      Int @default(0) @map("xp_points")
  currentLevel  Int @default(1) @map("current_level")
  totalXpEarned Int @default(0) @map("total_xp_earned")

  // Gamification relations
  currency             UserCurrency?
  streakData           StreakData?
  energy               UserEnergy?
  currencyTransactions CurrencyTransaction[]
  dailyActivities      UserDailyActivity[]

  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  users       User[]

  @@map("roles")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  isRevoked Boolean  @default(false) @map("is_revoked")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ==================== USER MODULE ====================

model UserCurrency {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  gems      Int      @default(0)
  coins     Int      @default(100)
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_currency")
}

model CurrencyTransaction {
  id           String                    @id @default(uuid())
  userId       String                    @map("user_id")
  currencyType CurrencyType              @map("currency_type")
  amount       Int
  reason       CurrencyTransactionReason
  metadata     Json?
  createdAt    DateTime                  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@map("currency_transactions")
}

model StreakData {
  id            String    @id @default(uuid())
  userId        String    @unique @map("user_id")
  currentStreak Int       @default(0) @map("current_streak")
  longestStreak Int       @default(0) @map("longest_streak")
  lastStudyDate DateTime? @map("last_study_date") @db.Date
  freezeCount   Int       @default(0) @map("freeze_count")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  history StreakHistory[]

  @@map("streak_data")
}

model StreakHistory {
  id           String   @id @default(uuid())
  streakDataId String   @map("streak_data_id")
  streakLength Int      @map("streak_length")
  startDate    DateTime @map("start_date") @db.Date
  endDate      DateTime @map("end_date") @db.Date
  endReason    String   @map("end_reason")
  createdAt    DateTime @default(now()) @map("created_at")

  streakData StreakData @relation(fields: [streakDataId], references: [id], onDelete: Cascade)

  @@index([streakDataId])
  @@map("streak_history")
}

model UserDailyActivity {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  activityDate  DateTime @map("activity_date") @db.Date
  xpEarned      Int      @default(0) @map("xp_earned")
  lessonsCount  Int      @default(0) @map("lessons_count")
  exerciseCount Int      @default(0) @map("exercise_count")
  streakCount   Int      @default(0) @map("streak_count")
  freezeUsed    Boolean  @default(false) @map("freeze_used")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, activityDate])
  @@index([userId, activityDate])
  @@map("user_daily_activities")
}

model UserEnergy {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  currentEnergy   Int      @default(5) @map("current_energy")
  maxEnergy       Int      @default(5) @map("max_energy")
  lastRechargeAt  DateTime @default(now()) @map("last_recharge_at")
  rechargeRateMin Int      @default(30) @map("recharge_rate_min")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_energy")
}

model UserLevel {
  level       Int     @id
  minXp       Int     @map("min_xp")
  maxXp       Int     @map("max_xp")
  title       String
  iconUrl     String? @map("icon_url")
  rewardGems  Int     @default(0) @map("reward_gems")
  rewardCoins Int     @default(0) @map("reward_coins")

  @@map("user_levels")
}


// ==================== SKILL / LEARNING MODULE ====================

model SkillPart {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(255)
  description String?  @db.Text
  position    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  skills Skill[]

  @@map("skill_parts")
}

model Skill {
  id          String   @id @default(uuid())
  title       String   @db.VarChar(255)
  description String?  @db.Text
  position    Int      @default(0)
  partId      String   @map("part_id")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  part           SkillPart       @relation(fields: [partId], references: [id], onDelete: Cascade)
  skillLevels    SkillLevel[]
  lessons        Lesson[]
  skillProgress  SkillProgress[]
  skillWords     SkillWord[]
  skillGrammars  SkillGrammar[]

  @@map("skills")
}

model SkillLevel {
  skillId String @map("skill_id")
  level   Int

  skill   Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@id([skillId, level])
  @@map("skill_levels")
}

model Lesson {
  id         String   @id @default(uuid())
  skillId    String   @map("skill_id")
  skillLevel Int      @map("skill_level")
  title      String   @db.VarChar(255)
  position   Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  skill     Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)
  skillLvl  SkillLevel @relation(fields: [skillId, skillLevel], references: [skillId, level], onDelete: Cascade)
  exercises Exercise[]

  @@map("lessons")
}

model Word {
  id            String   @id @default(uuid())
  content       String   @unique @db.VarChar(255)
  pronunciation String?  @db.VarChar(255)
  meaning       String?  @db.Text
  audioUrl      String?  @map("audio_url") @db.VarChar(255)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  wordMastery   WordMastery[]
  exerciseWords ExerciseWord[]
  skillWords    SkillWord[]
  wordTags      WordTag[]

  @@map("words")
}

model Grammar {
  id          String   @id @default(uuid())
  rule        String   @db.Text
  explanation String?  @db.Text
  examples    Json?    @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  grammarMastery   GrammarMastery[]
  exerciseGrammars ExerciseGrammar[]
  skillGrammars    SkillGrammar[]

  @@map("grammars")
}

model Tag {
  id   String @id @default(uuid())
  name String @unique @db.VarChar(50)

  wordTags WordTag[]

  @@map("tags")
}

model Vowel {
  id          String   @id @default(uuid())
  symbol      String   @unique @db.VarChar(10)
  name        String   @db.VarChar(100)
  description String?  @db.Text
  examples    Json?    @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  pronunciationLessons PronunciationLessonVowel[]
  masteryRecords       VowelMastery[]

  @@map("vowels")
}

model Consonant {
  id          String   @id @default(uuid())
  symbol      String   @unique @db.VarChar(10)
  name        String   @db.VarChar(100)
  description String?  @db.Text
  examples    Json?    @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  pronunciationLessons PronunciationLessonConsonant[]
  masteryRecords       ConsonantMastery[]

  @@map("consonants")
}

model Exercise {
  id           String       @id @default(uuid())
  lessonId     String       @map("lesson_id")
  exerciseType ExerciseType @map("exercise_type")
  prompt       String?      @db.Text
  meta         Json?        @db.JsonB
  position     Int          @default(0)
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  lesson           Lesson            @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  exerciseWords    ExerciseWord[]
  exerciseGrammars ExerciseGrammar[]
  exerciseResults  ExerciseResult[]

  @@map("exercises")
}

model PronunciationLesson {
  id          String   @id @default(uuid())
  title       String   @db.VarChar(255)
  description String?  @db.Text
  position    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  vowels     PronunciationLessonVowel[]
  consonants PronunciationLessonConsonant[]
  exercises  PronunciationExercise[]

  @@map("pronunciation_lessons")
}

model PronunciationLessonVowel {
  lessonId String @map("lesson_id")
  vowelId  String @map("vowel_id")

  lesson PronunciationLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  vowel  Vowel               @relation(fields: [vowelId], references: [id], onDelete: Cascade)

  @@id([lessonId, vowelId])
  @@map("pronunciation_lesson_vowels")
}

model PronunciationLessonConsonant {
  lessonId    String @map("lesson_id")
  consonantId String @map("consonant_id")

  lesson    PronunciationLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  consonant Consonant           @relation(fields: [consonantId], references: [id], onDelete: Cascade)

  @@id([lessonId, consonantId])
  @@map("pronunciation_lesson_consonants")
}

model PronunciationExercise {
  id           String       @id @default(uuid())
  lessonId     String       @map("lesson_id")
  exerciseType ExerciseType @map("exercise_type")
  prompt       String?      @db.Text
  meta         Json?        @db.JsonB
  position     Int          @default(0)
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  lesson          PronunciationLesson          @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  exerciseResults PronunciationExerciseResult[]

  @@map("pronunciation_exercises")
}

model PronunciationExerciseResult {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  exerciseId     String   @map("exercise_id")
  correctCount   Int      @map("correct_count") @default(0)
  incorrectCount Int      @map("incorrect_count") @default(0)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  exercise PronunciationExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@map("pronunciation_exercise_results")
}

model VowelMastery {
  userId       String    @map("user_id")
  vowelId      String    @map("vowel_id")
  masteryLevel Int       @default(0) @map("mastery_level")
  lastReview   DateTime? @map("last_review") @db.Timestamptz(6)

  vowel Vowel @relation(fields: [vowelId], references: [id], onDelete: Cascade)

  @@id([userId, vowelId])
  @@map("vowel_mastery")
}

model ConsonantMastery {
  userId       String    @map("user_id")
  consonantId  String    @map("consonant_id")
  masteryLevel Int       @default(0) @map("mastery_level")
  lastReview   DateTime? @map("last_review") @db.Timestamptz(6)

  consonant Consonant @relation(fields: [consonantId], references: [id], onDelete: Cascade)

  @@id([userId, consonantId])
  @@map("consonant_mastery")
}

// ==================== PROGRESS TRACKING ====================

model SkillProgress {
  userId         String    @id @map("user_id")
  skillId        String    @map("skill_id")
  levelReached   Int       @default(1) @map("level_reached")
  lessonPosition Int       @default(0) @map("lesson_position")
  lastPracticed  DateTime? @map("last_practiced") @db.Timestamptz(6)

  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@map("skill_progress")
}

model WordMastery {
  userId       String    @map("user_id")
  wordId       String    @map("word_id")
  masteryLevel Int       @default(0) @map("mastery_level")
  lastReview   DateTime? @map("last_review") @db.Timestamptz(6)

  word Word @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@id([userId, wordId])
  @@map("word_mastery")
}

model GrammarMastery {
  userId       String    @map("user_id")
  grammarId    String    @map("grammar_id")
  masteryLevel Int       @default(0) @map("mastery_level")
  lastReview   DateTime? @map("last_review") @db.Timestamptz(6)

  grammar Grammar @relation(fields: [grammarId], references: [id], onDelete: Cascade)

  @@id([userId, grammarId])
  @@map("grammar_mastery")
}

model ExerciseResult {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  exerciseId     String   @map("exercise_id")
  correctCount   Int      @map("correct_count") @default(0)
  incorrectCount Int      @map("incorrect_count") @default(0)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@map("exercise_results")
}

// ==================== JUNCTION TABLES ====================

model ExerciseWord {
  exerciseId String @map("exercise_id")
  wordId     String @map("word_id")

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  word     Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@id([exerciseId, wordId])
  @@map("exercise_words")
}

model ExerciseGrammar {
  exerciseId String @map("exercise_id")
  grammarId  String @map("grammar_id")

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  grammar  Grammar  @relation(fields: [grammarId], references: [id], onDelete: Cascade)

  @@id([exerciseId, grammarId])
  @@map("exercise_grammars")
}

model SkillWord {
  skillId String @map("skill_id")
  wordId  String @map("word_id")

  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)
  word  Word  @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@id([skillId, wordId])
  @@map("skill_words")
}

model SkillGrammar {
  skillId   String @map("skill_id")
  grammarId String @map("grammar_id")

  skill   Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)
  grammar Grammar @relation(fields: [grammarId], references: [id], onDelete: Cascade)

  @@id([skillId, grammarId])
  @@map("skill_grammars")
}

model WordTag {
  wordId String @map("word_id")
  tagId  String @map("tag_id")

  word Word @relation(fields: [wordId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([wordId, tagId])
  @@map("word_tags")
}
